    isLeft: 1
    sprite: {fileID: 21300000, guid: 3b9deed8b8c0a854ab7a4417e7f6bdf8, type: 3}
    callFunction: 0
    clazz: 
    method: 
  - name: "\uC77C\uCC28\uD568\uC218"
    text: "\uC6B0\uB9AC\uB97C \uC62E\uACA8\uC11C \uC544\uB798\uC758 \uCE78\uC5D0
      \uBC30\uCE58\uD574\uC918! \n\uC804\uC7A5 \uC704\uC5D0\uC11C \uB4DC\uB798\uADF8\uD558\uBA74
      \uBC30\uCE58\uB420 \uCE78\uC774 \uD45C\uC2DC\uB420 \uAC70\uC57C! "
    clearSprite: 0
    isLeft: 1
    sprite: {fileID: 21300000, guid: 3b9deed8b8c0a854ab7a4417e7f6bdf8, type: 3}
    callFunction: 0
    clazz: 
    method: 
  - name: 
    text: "\uC801\uC774 \uB098\uC624\uB294 \uC704\uCE58\uC5D0 \uACBD\uACE0 \uD45C\uC2DC\uAC00
      \uB744\uC6CC\uC9D1\uB2C8\uB2E4. \n\uACBD\uACE0 \uD45C\uC2DC\uB97C \uCC38\uACE0\uD558\uC5EC
