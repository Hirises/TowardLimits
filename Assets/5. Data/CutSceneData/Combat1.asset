    callFunction: 0
    clazz: 
    method: 
  - name: "\uC77C\uCC28\uD568\uC218"
    text: "\uBAA8\uB450 '\uC124\uB4DD'\uD558\uBA74\uC11C \uAC00\uB294 \uC218 \uBC16\uC5D0
      \uC5C6\uACA0\uB294\uAC78?"
